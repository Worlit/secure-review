# Server Configuration
# Порт, на котором будет запущен сервер
SERVER_PORT=8080
# Хост сервера
SERVER_HOST=0.0.0.0
# Режим работы Gin (debug, release, test)
GIN_MODE=debug

# Database Configuration
# URL подключения к PostgreSQL базе данных
# Формат: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/secure_review?sslmode=disable

# JWT Configuration
# Секретный ключ для подписи JWT токенов (сгенерируйте надежную строку)
JWT_SECRET=your-super-secret-key-change-me
# Время жизни токена в часах
JWT_EXPIRATION_HOURS=24

# GitHub Copilot / Models Configuration
# Токен доступа к GitHub Models API.
# Можно получить в https://github.com/marketplace/models (Playground -> Get API Key)
# Требуются права 'Models: Read-only' если создаете Fine-grained токен вручную.
COPILOT_API_KEY=github_pat_xxx...
# Модель для использования (например, gpt-4o, o1, o3-mini)
COPILOT_MODEL=gpt-4o
# URL API для GitHub Models (обычно менять не требуется, если используете стандартный endpoint)
COPILOT_API_URL=https://models.inference.ai.azure.com/chat/completions

# GitHub OAuth App Configuration
# Создайте OAuth App в GitHub: Settings -> Developer settings -> OAuth Apps
# Client ID вашего OAuth приложения
GITHUB_CLIENT_ID=your-github-client-id
# Client Secret вашего OAuth приложения
GITHUB_CLIENT_SECRET=your-github-client-secret
# Callback URL, который указан в настройках OAuth приложения
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# GitHub App Integration (Optional)
# Если используете GitHub App для интеграции с репозиториями
# ID приложения
GITHUB_APP_ID=
# Приватный ключ приложения (PEM формат)
GITHUB_APP_PRIVATE_KEY=
# Секрет для вебхуков
GITHUB_WEBHOOK_SECRET=

# Frontend Configuration
# URL фронтенд приложения (для CORS и редиректов)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
# Количество запросов
RATE_LIMIT_REQUESTS=100
# Период времени (например, 1m, 1h)
RATE_LIMIT_DURATION=1m

# Logging
# Уровень логирования (debug, info, warn, error)
LOG_LEVEL=info
# Формат логов (json, text)
LOG_FORMAT=json
